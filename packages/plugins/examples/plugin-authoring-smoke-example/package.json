{
  "name": "@proactiva/plugin-authoring-smoke-example",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "A Proactiva plugin",
  "scripts": {
    "prebuild": "node ../../../../scripts/ensure-plugin-build-deps.mjs",
    "build": "node ./esbuild.config.mjs",
    "build:rollup": "rollup -c",
    "dev": "node ./esbuild.config.mjs --watch",
    "dev:ui": "proactiva-plugin-dev-server --root . --ui-dir dist/ui --port 4177",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "pnpm --filter @proactiva/plugin-sdk build && tsc --noEmit"
  },
  "proactivaPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "keywords": [
    "proactiva",
    "plugin",
    "connector"
  ],
  "author": "Plugin Author",
  "license": "MIT",
  "dependencies": {
    "@proactiva/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "esbuild": "^0.27.3",
    "rollup": "^4.59.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
